# File: .env.example
# =============================================================================
# CryptoTrader AI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
# =============================================================================


# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# Which LLM to use for AI signal generation.
# Choose ONE of: anthropic | openai | groq | ollama | openrouter | gemini | mistral | together
LLM_PROVIDER=anthropic

# Override the default model for your chosen provider (optional).
# Leave blank to use the provider's recommended default.
#
# Provider defaults and example model values:
#   anthropic  → claude-sonnet-4-5-20251022
#                other: claude-opus-4-5, claude-haiku-4-5-20251001
#   openai     → gpt-4o-mini
#                other: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
#   groq       → llama-3.3-70b-versatile
#                other: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
#   ollama     → llama3.2
#                other: mistral, qwen2.5, phi3, deepseek-r1, gemma2, codellama
#   openrouter → meta-llama/llama-3.3-70b-instruct
#                other: mistralai/mistral-large, google/gemini-flash-1.5
#   gemini     → gemini-2.0-flash
#                other: gemini-1.5-pro, gemini-1.5-flash
#   mistral    → mistral-large-latest
#                other: mistral-medium-latest, open-mixtral-8x22b
#   together   → meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#                other: Qwen/Qwen2.5-72B-Instruct-Turbo, deepseek-ai/DeepSeek-V3
LLM_MODEL=

# Comma-separated fallback providers tried in order if the primary fails.
# Example: LLM_FALLBACK_PROVIDERS=groq,ollama
# Leave blank to disable fallback.
LLM_FALLBACK_PROVIDERS=


# =============================================================================
# LLM API KEYS
# Only the key for your chosen LLM_PROVIDER needs to be set.
# =============================================================================

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq Cloud (free tier available) — https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (200+ models, some free) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini (free tier available) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Mistral AI — https://console.mistral.ai/
MISTRAL_API_KEY=

# Together AI (free $25 credit on signup) — https://api.together.ai/
TOGETHER_API_KEY=

# Ollama — runs locally, no API key needed
# Install: https://ollama.com  |  Pull a model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434


# =============================================================================
# EXCHANGE API KEYS
# =============================================================================

# Crypto.com Exchange — https://exchange.crypto.com
# Go to: Settings → API Management → Create API Key
# Enable: Trade only. NEVER enable Withdraw.
CRYPTOCOM_API_KEY=
CRYPTOCOM_API_SECRET=
CRYPTOCOM_SANDBOX=true        # true = testnet (safe) | false = live

# Binance (optional, via CCXT) — https://www.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true


# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Mode: paper (safe simulation) | live (real money, validate first!)
TRADING_MODE=paper

# Symbols to watch (Crypto.com format: BASE_QUOTE)
SYMBOLS=BTC_USDT,ETH_USDT,SOL_USDT,BNB_USDT,XRP_USDT

# How often to scan all symbols and run the agent cycle (seconds)
SCAN_INTERVAL_SECONDS=30

BASE_CURRENCY=USDT
INITIAL_CAPITAL=10000


# =============================================================================
# RISK MANAGEMENT  (enforced on every single trade, no exceptions)
# =============================================================================

MAX_POSITION_SIZE_PCT=5.0     # Max % of portfolio per trade
STOP_LOSS_PCT=2.0             # Default stop-loss below entry
TAKE_PROFIT_PCT=4.0           # Default take-profit above entry
MAX_DAILY_LOSS_PCT=5.0        # Auto-pause if daily loss exceeds this
MAX_DRAWDOWN_PCT=15.0         # Auto-pause if portfolio drawdown exceeds this
MAX_OPEN_POSITIONS=5          # Max concurrent open trades


# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=sqlite:///./trading.db
# PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/cryptotrader


# =============================================================================
# API SERVER
# =============================================================================

API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-in-production
LOG_LEVEL=INFO


# =============================================================================
# NOTIFICATIONS (optional)
# =============================================================================

# Telegram: https://core.telegram.org/bots#creating-a-new-bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
